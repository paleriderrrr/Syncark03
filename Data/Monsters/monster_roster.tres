category = &"fruit"
base_hp = 320
base_attack = 25.0
attack_interval = 3.0
skill_summary = "每次攻击使被攻击者遭到[腐蚀]，额外扣除3点生命。"
target_rule = &"default_frontline"

[sub_resource type="Resource" id="MonsterDefinition_dessert"]
