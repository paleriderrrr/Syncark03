[gd_resource type="Resource" script_class="MonsterRoster" load_steps=10 format=3]

[ext_resource type="Script" path="res://Scripts/Data/monster_roster.gd" id="1_roster"]
[ext_resource type="Script" path="res://Scripts/Data/monster_definition.gd" id="2_definition"]

[sub_resource type="Resource" id="MonsterDefinition_fruit"]
script = ExtResource("2_definition")
id = &"fruit_tree_king"
display_name = "枝枝树灵王"
category = &"fruit"
base_hp = 320
base_attack = 25.0
attack_interval = 3.0
skill_summary = "战斗开始时使所有敌人遭到[腐蚀]。腐蚀：每秒额外扣除1点生命值，持续25秒。"
target_rule = &"default_frontline"

[sub_resource type="Resource" id="MonsterDefinition_dessert"]
script = ExtResource("2_definition")
id = &"cream_overlord"
display_name = "奶油团团霸"
category = &"dessert"
base_hp = 300
base_attack = 10.0
attack_interval = 1.2
skill_summary = "【奶甜甜】每5秒恢复20生命值。\n【软绵绵】每次受击时降低对自己造成伤害的角色的1点攻击力，单个角色至多5点。"
target_rule = &"default_frontline"

[sub_resource type="Resource" id="MonsterDefinition_meat"]
script = ExtResource("2_definition")
id = &"charging_beast"
display_name = "冲冲牛龙兽"
category = &"meat"
base_hp = 200
base_attack = 40.0
attack_interval = 2.0
skill_summary = "战斗开始时随机使一名角色失去自己的饭盒效果5秒；生命值降低至50%时，立刻随机对一名角色造成50点伤害。"
target_rule = &"random_role"

[sub_resource type="Resource" id="MonsterDefinition_drink"]
script = ExtResource("2_definition")
id = &"water_giant"
display_name = "哗哗水巨人"
category = &"drink"
base_hp = 300
base_attack = 15.0
attack_interval = 2.0
skill_summary = "在50%生命值以下时，每次受到的伤害降低1点。若攻击对象生命值高于50%，每次攻击额外造成3点伤害。"
target_rule = &"default_frontline"

[sub_resource type="Resource" id="MonsterDefinition_staple"]
script = ExtResource("2_definition")
id = &"bread_knight"
display_name = "面饱饱骑士"
category = &"staple"
base_hp = 340
base_attack = 22.0
attack_interval = 2.5
skill_summary = "开局带有5层面包糠。面包糠：受到伤害时抵消伤害，每次抵消扣除一层。每次攻击赋予一层破甲，单个角色至多5层。破甲：每次受到的伤害增加10%。"
target_rule = &"default_frontline"

[sub_resource type="Resource" id="MonsterDefinition_spice"]
script = ExtResource("2_definition")
id = &"spice_wizard"
display_name = "高菌菌巫师"
category = &"spice"
base_hp = 290
base_attack = 22.0
attack_interval = 1.8
skill_summary = "每5秒赋予一次治疗限制效果。治疗限制：恢复的生命值减少50%，持续3秒。攻击拥有治疗限制的目标时，额外造成其当前生命值1%伤害。"
target_rule = &"random_role"

[sub_resource type="Resource" id="MonsterDefinition_boss"]
script = ExtResource("2_definition")
id = &"nc2_auto_cooker"
display_name = "NC-2复合型自动烹饪机"
category = &"boss"
base_hp = 1000
base_attack = 60.0
attack_interval = 5.0
skill_summary = "每受到30次攻击，变换一次敌方角色的站位（仇恨）。第三次攻击使命中的目标失去所有行动能力3秒。"
target_rule = &"default_frontline"

[resource]
script = ExtResource("1_roster")
monsters = [SubResource("MonsterDefinition_fruit"), SubResource("MonsterDefinition_dessert"), SubResource("MonsterDefinition_meat"), SubResource("MonsterDefinition_drink"), SubResource("MonsterDefinition_staple"), SubResource("MonsterDefinition_spice"), SubResource("MonsterDefinition_boss")]
