[gd_resource type="Resource" script_class="MonsterRoster" load_steps=10 format=3]

[ext_resource type="Script" path="res://Scripts/Data/monster_roster.gd" id="1_roster"]
[ext_resource type="Script" path="res://Scripts/Data/monster_definition.gd" id="2_definition"]

[sub_resource type="Resource" id="MonsterDefinition_fruit"]
script = ExtResource("2_definition")
id = &"fruit_tree_king"
