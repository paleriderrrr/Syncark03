[resource]
script = ExtResource("1_roster")
monsters = [SubResource("MonsterDefinition_fruit"), SubResource("MonsterDefinition_dessert"), SubResource("MonsterDefinition_meat"), SubResource("MonsterDefinition_drink"), SubResource("MonsterDefinition_staple"), SubResource("MonsterDefinition_spice"), SubResource("MonsterDefinition_boss")]

